# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==========================================
# Copy to .env.local for local dev, or add in Vercel Dashboard

# ---- DATABASE ----
# Use Neon (neon.tech), Supabase, or Railway for managed PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ---- AUTH ----
NEXTAUTH_URL="https://alkhewani.cloud"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ---- EMAIL (SendGrid) ----
SENDGRID_API_KEY="SG.xxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="hello@alkhewani.cloud"
SENDGRID_FROM_NAME="The Husky Experience"

# ---- PAYMENTS (Stripe) ----
STRIPE_SECRET_KEY="sk_live_xxxxxxxxxxxx"
STRIPE_PUBLISHABLE_KEY="pk_live_xxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# ---- OPTIONAL ----
# GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
# CLOUDINARY_CLOUD_NAME="your-cloud"
# CLOUDINARY_API_KEY="xxx"
# CLOUDINARY_API_SECRET="xxx"
# GOOGLE_MAPS_API_KEY="xxx"